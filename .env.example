# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname

# JWT signing secret — usa una stringa lunga e casuale (min 32 caratteri)
JWT_SECRET=cambia-questa-stringa-con-qualcosa-di-random

# Cliente (usato come chiave in parking_state)
PARKING_CLIENTE=retelit

# Segreto per proteggere db-init (chiamato una sola volta dopo il deploy)
INIT_SECRET=segreto-per-db-init

# Password iniziali Super Admin (usate solo da db-init)
SUPER_ADMIN_PASS_1=password-per-fede-parkingcloud
SUPER_ADMIN_PASS_2=password-per-team-parkingcloud
